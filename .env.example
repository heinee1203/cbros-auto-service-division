# ==============================================================================
# AutoServ Pro — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.

# Database (Railway auto-injects this when PostgreSQL addon is added)
DATABASE_URL=postgresql://user:password@host:5432/autoserv

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Photo storage (default: ./public/uploads for local dev)
# For Railway: set to a volume mount path like /data/photos
# PHOTO_STORAGE_PATH=/data/photos

# Cron job secret (for scheduled SMS/notification routes)
# CRON_SECRET=generate-a-random-string

# Apex POS Integration (optional — configure in Settings UI)
# APEX_POS_API_URL=https://apex-pos.up.railway.app
# APEX_POS_API_KEY=your-api-key

# SMS via Semaphore (configured in Settings UI, not env vars)
# SEMAPHORE_API_KEY is stored in the Settings table
